{
  "manifest_version": 3,
  "name": "电商商品图片提取器",
  "description": "识别 Amazon、AliExpress、SHEIN 商品详情页 SKU 图和搜索结果页封面图，预览勾选后批量下载。",
  "version": "0.2.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "提取商品图片",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://amazon.com/*",
    "https://*.media-amazon.com/*",
    "https://m.media-amazon.com/*",
    "https://images-na.ssl-images-amazon.com/*",
    "https://www.aliexpress.com/*",
    "https://aliexpress.com/*",
    "https://*.aliexpress.com/*",
    "https://*.alicdn.com/*",
    "https://*.aliexpress-media.com/*",
    "https://us.shein.com/*",
    "https://shein.com/*",
    "https://*.shein.com/*",
    "https://*.ltwebstatic.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://amazon.com/*",
        "https://www.aliexpress.com/*",
        "https://aliexpress.com/*",
        "https://*.aliexpress.com/*",
        "https://us.shein.com/*",
        "https://shein.com/*",
        "https://*.shein.com/*"
      ],
      "js": [
        "amazonAdapter.js",
        "amazonSearchAdapter.js",
        "marketplaceAdapters.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
