{
  "manifest_version": 3,
  "name": "亚马逊商品图片下载助手",
  "description": "快速下载亚马逊商品图片，并支持 AliExpress、SHEIN 商品详情页和搜索结果页图片整理。",
  "version": "0.2.1",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "亚马逊商品图片下载助手",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://amazon.com/*",
    "https://*.media-amazon.com/*",
    "https://m.media-amazon.com/*",
    "https://images-na.ssl-images-amazon.com/*",
    "https://www.aliexpress.com/*",
    "https://aliexpress.com/*",
    "https://*.aliexpress.com/*",
    "https://*.alicdn.com/*",
    "https://*.aliexpress-media.com/*",
    "https://us.shein.com/*",
    "https://shein.com/*",
    "https://*.shein.com/*",
    "https://*.ltwebstatic.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://amazon.com/*",
        "https://www.aliexpress.com/*",
        "https://aliexpress.com/*",
        "https://*.aliexpress.com/*",
        "https://us.shein.com/*",
        "https://shein.com/*",
        "https://*.shein.com/*"
      ],
      "js": [
        "amazonAdapter.js",
        "amazonSearchAdapter.js",
        "marketplaceAdapters.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
